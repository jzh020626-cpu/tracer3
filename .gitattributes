* text=auto eol=lf

# Linux runtime and source files must keep LF line endings.
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hh text eol=lf
*.hpp text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.tsv text eol=lf
*.env text eol=lf
*.service text eol=lf
*.rules text eol=lf
*.conf text eol=lf

# Documentation and captured assets are binary.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.xlsx binary
*.xls binary
*.zip binary
*.gz binary
*.tar binary
